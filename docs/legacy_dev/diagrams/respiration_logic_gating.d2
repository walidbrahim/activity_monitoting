direction: down

OccupancyGating: {
  label: "1. Occupancy Verification"
  
  Input: {
    shape: rectangle
    label: "ActivityEngine Payload"
  }
  
  OccGate: {
    shape: diamond
    label: "is_valid AND\n'Bed' in zone ?"
  }
  
  Reset: {
    shape: rectangle
    label: "Reset Buffers\nShow 'NOT IN BED'"
  }
}

MotionPostureGating: {
  label: "2. Motion & Posture Gating"
  
  Scorer: {
    shape: rectangle
    label: "Motion Scorer\n(A+B Hybrid based on Tracker)"
  }
  
  NormScore: {
    shape: rectangle
    label: "Normalized Motion Score\n(0 = Resting, >1 = Moving)"
  }
  
  ComputeConf: {
    shape: rectangle
    label: "compute_confidence()\nMotion Deadband + Posture Penalty"
  }
  
  PostureLabel: {
    shape: rectangle
    label: "Posture Class\n(Lying 1.0, Sitting 0.5, Standing 0.2)"
  }
  
  FinalConf: {
    shape: rectangle
    label: "Final Quality %\nConf = MotionFactor * PostureFactor"
  }
}

RespPipeline: {
  label: "3. Respiration Extraction & Display"

  Extraction: {
    shape: rectangle
    label: "Phase Processing\n(Fusion -> Unwrap)"
  }
  
  PathSplit: {
    shape: rectangle
    label: "Path Split"
  }
  
  Bandpass: {
    shape: rectangle
    label: "DISPLAY PATH\nBandpass 0.05 - 0.5 Hz\nFixed physical scale"
  }
  
  Derivative: {
    shape: rectangle
    label: "APNEA PATH\nDifference -> Lowpass -> Abs Grad"
  }
  
  ApneaLogic: {
    shape: rectangle
    label: "Apnea Detection\nDynamic Threshold on Derivative"
  }
  
  MarkerGate: {
    shape: diamond
    label: "Final Quality >= 40% ?"
  }
  
  RenderWaves: {
    shape: rectangle
    label: "Always render Waveform &\nApnea Events"
  }
  
  RenderMarkers: {
    shape: rectangle
    label: "Update RR History\nRender Inhale/Exhale Markers"
  }
  
  MaskMarkers: {
    shape: rectangle
    label: "Mask RR History (NaN)\nHide Markers"
  }
}

OccupancyGating.Input -> OccupancyGating.OccGate
OccupancyGating.OccGate -> OccupancyGating.Reset: "No"
OccupancyGating.OccGate -> MotionPostureGating.Scorer: "Yes"

MotionPostureGating.Scorer -> MotionPostureGating.NormScore
MotionPostureGating.NormScore -> MotionPostureGating.ComputeConf
MotionPostureGating.PostureLabel -> MotionPostureGating.ComputeConf
MotionPostureGating.ComputeConf -> MotionPostureGating.FinalConf

MotionPostureGating.FinalConf -> RespPipeline.Extraction
RespPipeline.Extraction -> RespPipeline.PathSplit
RespPipeline.PathSplit -> RespPipeline.Bandpass
RespPipeline.PathSplit -> RespPipeline.Derivative

RespPipeline.Bandpass -> RespPipeline.RenderWaves
RespPipeline.Derivative -> RespPipeline.ApneaLogic
RespPipeline.ApneaLogic -> RespPipeline.RenderWaves

RespPipeline.RenderWaves -> RespPipeline.MarkerGate
RespPipeline.MarkerGate -> RespPipeline.RenderMarkers: "Yes"
RespPipeline.MarkerGate -> RespPipeline.MaskMarkers: "No"
