direction: down

Inputs: {
  label: "Inputs"
  
  SpecHist: {
    shape: rectangle
    label: "spectral_history"
  }
  
  Lock: {
    shape: rectangle
    label: "locked_bin"
  }
  
  CoarseScore: {
    shape: rectangle
    label: "coarse_motion_level\n(Activity Pipeline)"
  }
  
  Posture: {
    shape: rectangle
    label: "posture_conf &\nposture_str"
  }
}

Scoring: {
  label: "Raw Score Computation"
  
  ScoreA: {
    shape: rectangle
    label: "Score A (Unlocked)\nmax per-bin std of |spectral_history|"
  }
  
  ScoreB: {
    shape: rectangle
    label: "Score B (Locked)\nIQR of |Δphase| at locked_bin"
  }
  
  Blend: {
    shape: diamond
    label: "Lock Status ?"
  }
  
  RawOut: {
    shape: rectangle
    label: "Raw Score\n(A, B, or 5-frame Blend)"
  }
}

AutoCalib: {
  label: "Auto-Calibration Pool"
  
  StableGate: {
    shape: diamond
    label: "Stability Gate\ncoarse_motion < restless_max\nAND posture_conf > 60%\nAND posture_str != Unknown"
  }
  
  Pool: {
    shape: rectangle
    label: "Append to 30s Pool\n(max size = 30 * fps)"
  }
  
  ThreshCalc: {
    shape: rectangle
    label: "Update Threshold\n(if pool >= 30 samples)\nThreshold = max(0.5, P10(pool) * 6.0)"
  }
}

Output: {
  label: "Binary Decision & Output"
  
  NormCalc: {
    shape: rectangle
    label: "norm_score = raw / threshold"
  }
  
  Decision: {
    shape: diamond
    label: "norm_score > 1.0 ?"
  }
  
  StateStr: {
    shape: rectangle
    label: "Moving vs. Still\n(or 'Calibrating')"
  }
}

Inputs.SpecHist -> Scoring.ScoreA
Inputs.SpecHist -> Scoring.ScoreB
Inputs.Lock -> Scoring.ScoreB
Inputs.Lock -> Scoring.Blend

Scoring.ScoreA -> Scoring.Blend
Scoring.ScoreB -> Scoring.Blend
Scoring.Blend -> Scoring.RawOut

Scoring.RawOut -> AutoCalib.StableGate
Inputs.CoarseScore -> AutoCalib.StableGate
Inputs.Posture -> AutoCalib.StableGate

AutoCalib.StableGate -> AutoCalib.Pool: "Yes"
AutoCalib.Pool -> AutoCalib.ThreshCalc

AutoCalib.ThreshCalc -> Output.NormCalc
Scoring.RawOut -> Output.NormCalc

Output.NormCalc -> Output.Decision
Output.Decision -> Output.StateStr
