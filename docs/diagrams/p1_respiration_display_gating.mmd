flowchart TD
    A["Input stream 1 (activity)<br/>In: engine activity dict<br/>Out: zone/posture/motion_score/motion_str/validity"]
    R["Input stream 2 (respiration)<br/>In: engine respiration dict<br/>Out: live signal, RR, apnea, quality"]

    A --> G1{"(1) On-bed eligibility gate<br/>In: is_valid + zone + final_bin + spectral_history<br/>Out: in_bed bool"}

    G1 -- "No" --> N1["(1a) Out-of-bed handling<br/>In: in_bed=False<br/>Out: reset buffers + warning + paused respiration display"]

    G1 -- "Yes" --> Y1["(1b) In-bed handling<br/>In: in_bed=True<br/>Out: continue live update path"]

    Y1 --> MS["(2) Motion path (engine-native)<br/>In: motion_score + motion_str<br/>Out: moving/still state"]
    MS --> C1["(2b) Motion state projection<br/>In: motion_score + label<br/>Out: UI motion state text"]
    C1 --> Q["(3) Compute signal confidence<br/>In: motion_score + posture<br/>Out: confidence %"]

    Q --> G2{"(4) Marker confidence gate<br/>In: confidence %<br/>Out: show/hide markers"}
    G2 -- "Pass" --> M1["Show inhale/exhale markers<br/>In: confidence >= 40%<br/>Out: marker overlay visible"]
    G2 -- "Fail" --> M2["Hide inhale/exhale markers<br/>In: confidence < 40%<br/>Out: marker overlay hidden"]

    Q --> V1["(5) Quality-driven visuals<br/>In: confidence %<br/>Out: line opacity + quality badge"]

    R --> G3{"(6) Respiration payload gate<br/>In: resp payload present?<br/>Out: render/clear action"}
    G3 -- "No" --> R0["Clear apnea overlays and markers<br/>In: missing resp payload<br/>Out: clean plot state"]
    G3 -- "Yes" --> R1["Render respiration panels<br/>In: resp payload<br/>Out: signal, RR trend, apnea regions, derivative"]

    R --> B{"(7) Resp calibration badge gate<br/>In: resp.is_calibrating + in_bed<br/>Out: badge text"}
    B -- "Calibrating" --> B1["Status badge: CALIBRATING<br/>In: is_calibrating=True<br/>Out: orange badge"]
    B -- "Ready (and in-bed)" --> B2["Status badge: LIVE<br/>In: is_calibrating=False and in_bed=True<br/>Out: green badge"]
    AN1["On-bed condition: is_valid and zone contains Bed and final_bin exists and spectral_history exists."]:::note
    AN2["Motion source: motion_score is consumed directly from radar_engine (no GUI-side rescoring)."]:::note
    AN3["Motion gate formula: moving if motion_score >= rest_max/restless_max (or moving label e.g. WALKING/SHIFTING)."]:::note
    AN4["Confidence formula: lower=0.20, upper=0.85; confidence = motion_factor(motion_score) x posture_factor x 100."]:::note
    AN5["Marker gate: inhale/exhale markers are shown only when confidence >= 40%."]:::note
    AN6["Respiration calibration: badge shows CALIBRATING during extractor startup calibration window (~40 s)."]:::note
    G1 -.-> AN1
    MS -.-> AN2
    MS -.-> AN3
    Q -.-> AN4
    G2 -.-> AN5
    B -.-> AN6

    classDef input fill:#E0F2FE,stroke:#0284C7,color:#0C4A6E;
    classDef gate fill:#FEF3C7,stroke:#F59E0B,color:#78350F;
    classDef action fill:#ECFDF5,stroke:#10B981,color:#064E3B;
    classDef note fill:#FFFBEB,stroke:#D97706,color:#7C2D12,stroke-dasharray: 4 3;
    class A,R input;
    class G1,G2,G3,B gate;
    class N1,Y1,MS,C1,Q,M1,M2,V1,R0,R1,B1,B2 action;
