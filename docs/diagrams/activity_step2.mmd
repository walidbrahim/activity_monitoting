graph TD
    Input["<b>Input:</b> dynamic_data,<br/>dynamic_mag_profile"] --> InitSearch["Set min search bin (30cm)"]
    
    InitSearch --> FindPeaks["Identify top 15 peaks in Dynamic Mag Profile<br/>(above min distance)"]
    FindPeaks --> LoopCand["<b>Iterate over Candidate Peaks</b>"]
    
    subgraph "1. Angle Estimation & 3D Projection (DSP)"
        LoopCand --> GetChan["Get 8-channel complex data for this bin"]
        GetChan --> FormatMat["Format Antenna Matrix S_cand"]
        FormatMat --> EstAngle["Estimate Phase Angle via Sum/Conj:<br/>om_az (Azimuth), om_el (Elevation)"]
        EstAngle --> CalcAngle["Convert Phase to Angles:<br/>az_cand, el_cand (arcsin)"]
        CalcAngle --> ProjRad["<b>Project to Radar Coords (Pr_c)</b><br/>X=R*sin(Az)*cos(El),<br/>Y=R*cos(Az)*cos(El),<br/>Z=R*sin(El)"]
        ProjRad --> ProjRoom["<b>Project to Room Coords (Pb_c)</b><br/>Apply Rotation Matrix self.R,<br/>Add Translation Vector self.T"]
    end
    
    subgraph "2. Spatial Evaluation & Vital Sign Gating"
        ProjRoom --> ZoneEval["Call evaluate_spatial_zone with Room Coords"]
        ZoneEval --> IsRoom{"Is Point valid AND<br/>not Ghost Zone?"}
        
        IsRoom -- Yes --> CheckSpectral["Is Spectral Buffer full?"]
        IsRoom -- No --> Next["Next Candidate"]
        
        CheckSpectral -- Yes --> PhaseExt["Extract Phase History for this bin"]
        CheckSpectral -- No --> SetLowMult["Vital Multiplier = 0.1"]
        
        subgraph "Spectral Analysis (Breathing)"
            PhaseExt --> Detrend["Unwrap Phase & Detrend (scipy.signal)"]
            Detrend --> Window["Apply Hanning Window"]
            Window --> FFT["<b>Slow-Time FFT (np.fft.rfft)</b><br/>Complex to Magnitude spectrum"]
            FFT --> SNRC["Define Breathing (0.15-0.5Hz) & Noise (1-3Hz) bands.<br/>Calculate <b>Breathing SNR</b>"]
            SNRC --> Logic{"Is SNR > 1.0 (Breathing)?<br/>Else SNR > 0.6 (Active)?<br/>Else Phase Jump > 10 (Major Motion)?"}
            Logic -- Breathing --> V1["Vital Mult = 1.0"]
            Logic -- Active --> V2["Vital Mult = 0.5"]
            Logic -- Major --> V3["Vital Mult = 0.9"]
            Logic -- Static/Noisy --> V4["Vital Mult = 0.1"]
        end
        
        V1 --> PushValid["Add to valid_candidates list"]
        V2 --> PushValid
        V3 --> PushValid
        V4 --> PushValid
        SetLowMult --> PushValid
        PushValid --> Next
    end
    
    Next --> DecExists{"Any Valid Candidates Found?"}
    
    subgraph "3. Candidate Scoring & Tethering"
        DecExists -- Yes --> ScoreAll["<b>Score Candidates (use_tethering=True)</b><br/>Score = (Mag/MaxMag)*VitalMult + ZoneBonus - SpatialPenalty"]
        
        ScoreAll --> CheckReassess["Interval for Reassessment (every 3s)?"]
        
        CheckReassess -- Yes --> ScoreUntether["Score WITHOUT Tethering"]
        ScoreUntether --> Better?{"Is Untethered winner substantially better<br/>(Score + 0.2)?"}
        Better? -- Yes --> SetWinnerU["Set Best=Untethered,<br/>Reset existing smoothed track"]
        Better? -- No --> SetWinnerT["Set Best=Tethered Winner"]
        CheckReassess -- No --> SetWinnerT
        
        SetWinnerT --> OutputC["<b>Output:</b> raw_x, raw_y, raw_z,<br/>is_valid_point=True,<br/>Current Zone"]
        SetWinnerU --> OutputC
    end
    
    DecExists -- No --> Fallback["is_valid_point=False<br/>Target raw peak bin"]
    Fallback --> OutputC