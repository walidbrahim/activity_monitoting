graph TD
    Input["<b>Input:</b> dynamic_data,<br/>dynamic_mag_profile"] --> InitSearch["Set min_search_bin from<br/>config.tuning.min_search_range"]
    
    InitSearch --> FindPeaks["Identify top N peaks in Dynamic Mag Profile<br/>(N = config.tuning.num_candidates)"]
    FindPeaks --> GetOrdered["<b>Get Ordered Spectral History</b><br/>Reconstruct time-ordered view from ring buffer"]
    GetOrdered --> LoopCand["<b>Iterate over Candidate Peaks</b>"]
    
    subgraph "1. Angle Estimation & 3D Projection (DSP)"
        LoopCand --> GetChan["Get 8-channel complex data for this bin"]
        GetChan --> FormatMat["Format Antenna Matrix S_cand (4x2)"]
        FormatMat --> EstAngle["Estimate Phase via Sum/Conj:<br/>om_az (Azimuth), om_el (Elevation)"]
        EstAngle --> CalcAngle["Convert Phase to Angles:<br/>az_cand, el_cand (arcsin + clip)"]
        CalcAngle --> ProjRad["<b>Project to Radar Coords (Pr_c)</b><br/>X=R*sin(Az)*cos(El),<br/>Y=R*cos(Az)*cos(El),<br/>Z=R*sin(El)"]
        ProjRad --> ProjRoom["<b>Project to Room Coords (Pb_c)</b><br/>Apply Rotation Matrix (from _build_rotation),<br/>Add Translation Vector T"]
    end
    
    subgraph "2. Spatial Evaluation & Vital Sign Gating"
        ProjRoom --> ZoneEval["evaluate_spatial_zone(x, y, z)"]
        ZoneEval --> IsRoom{"Valid target AND<br/>not Ghost Zone?"}
        
        IsRoom -- Yes --> CheckSpectral{"Spectral Buffer<br/>full?"}
        IsRoom -- No --> Next["Next Candidate"]
        
        CheckSpectral -- Yes --> PhaseExt["Extract Phase History from ordered spectral"]
        CheckSpectral -- No --> SetLowMult["vital_mult = 0.1<br/>micro_state = STABLE"]
        
        subgraph "Phase-Variance / SQI Classification"
            PhaseExt --> UnwrapPhase["Unwrap Phase, Compute phase_var & displacement_mm"]
            UnwrapPhase --> VarGate{"phase_var < ghost_threshold?"}
            VarGate -- Yes --> V_Ghost["vital_mult = 0.01<br/>micro_state = STATIC_GHOST"]
            VarGate -- No --> DispGate{"displacement_mm > macro_thresh?"}
            DispGate -- Yes --> V_Macro["vital_mult = 0.9<br/>micro_state = MACRO_PHASE"]
            DispGate -- No --> MicroGate{"phase_var > 0.3?"}
            MicroGate -- Yes --> V_Micro["vital_mult = 0.7<br/>micro_state = MICRO_PHASE"]
            MicroGate -- No --> SQI["<b>Spectral Quality Index (SQI)</b><br/>Detrend, Hanning Window, FFT<br/>SQI = vital_energy(0.15-0.7Hz) /<br/>total_energy(0.15-3.0Hz)"]
            SQI --> SQIGate{"SQI > 0.45?"}
            SQIGate -- Yes --> V_Bio["vital_mult = 1.0<br/>(Biological/Breathing)"]
            SQIGate -- No --> SQIMed{"SQI > 0.25?"}
            SQIMed -- Yes --> V_Amb["vital_mult = 0.5"]
            SQIMed -- No --> V_Dead["vital_mult = 0.05<br/>micro_state = DEAD_SPACE"]
        end
        
        V_Ghost --> PushValid["Add to valid_candidates list"]
        V_Macro --> PushValid
        V_Micro --> PushValid
        V_Bio --> PushValid
        V_Amb --> PushValid
        V_Dead --> PushValid
        SetLowMult --> PushValid
        PushValid --> Next
    end
    
    Next --> DecExists{"Any Valid<br/>Candidates?"}
    
    subgraph "3. Candidate Scoring, Tethering & Jump Rejection"
        DecExists -- Yes --> ScoreAll["<b>_score_candidates(use_tethering)</b><br/>Score = f(mag_ratio, vital_mult,<br/>zone_bonus, sticky_bin, anatomy_tether)<br/>Monitor mode: vital_mult weighted 2x"]
        
        ScoreAll --> SelectBest["Select best candidate,<br/>Set current_active_zone & micro_state"]
        SelectBest --> ClipZ["Clip Z to [z_clip_min, z_clip_max]<br/>from config.tuning"]
        ClipZ --> JumpGate{"Track exists AND<br/>jump_dist > jump_reject_distance?"}
        JumpGate -- Yes --> Reject["is_valid_point = False<br/>is_jump = True"]
        JumpGate -- No --> Accept["is_valid_point = True"]
        
        Accept --> OutputC["<b>Output:</b> raw_x, raw_y, raw_z,<br/>is_valid_point, is_jump,<br/>final_peak_bin, dynamic_peak_bin"]
        Reject --> OutputC
    end
    
    DecExists -- No --> Fallback["is_valid_point = False<br/>Use top peak as dynamic_peak_bin"]
    Fallback --> OutputC