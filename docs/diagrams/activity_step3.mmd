graph TD
    Input["<b>Input:</b> dynamic_mag_profile, peak_bin,<br/>raw_x/y/z, is_jump, raw_mag_profile,<br/>corrected_data, is_occupied"] --> CheckFeature{"apnea_state<br/>feature enabled?"}
    
    CheckFeature -- No --> RawMode{"Dynamic Mag >=<br/>Detection Threshold?"}
    RawMode -- Yes --> RawOcc["is_occupied=True<br/>status=Occupied (Raw Detection)"]
    RawMode -- No --> EmptyRaw["empty_room(), abort"]
    
    CheckFeature -- Yes --> DynCheck{"Dynamic Mag >= Threshold<br/>AND not is_jump<br/>AND micro_state not<br/>DEAD_SPACE/STATIC_GHOST?"}
    
    DynCheck -- Yes --> EntryGate{"Already occupied?"}
    EntryGate -- Yes --> S1_Active["<b>STATE: Active/Breathing</b><br/>apnea_frames = 0<br/>Capture occupied_reflection"]
    EntryGate -- No --> EntryHold{"entry_frames <<br/>frames_to_occupy?"}
    EntryHold -- Yes --> AbortEntry["Still warming entry, abort"]
    EntryHold -- No --> S1_Active
    S1_Active --> OutputMachine
    
    DynCheck -- No --> ApneaGate{"is_occupied AND<br/>last_target_bin known?"}
    ApneaGate -- No --> S4["<b>STATE: Truly Empty</b><br/>empty_room(), abort"]
    
    ApneaGate -- Yes --> GetZone["Get last known position zone"]
    GetZone --> StripZone["<b>Strip sub-zone suffix</b><br/>base_zone = zone.split(' - ')[0]<br/>(e.g. 'Bed - Center' → 'Bed')"]
    StripZone --> LookupType["config.layout[base_zone].type == 'monitor'?"]
    
    LookupType -- "Not Monitor" --> ExitState["<b>STATE: Confirmed Exit</b><br/>Clear state, snapshot clutter map,<br/>empty_room(), abort"]
    
    LookupType -- Monitor --> ReflCheck{"current_raw_reflection ><br/>occupied_reflection * 0.70?"}
    ReflCheck -- No --> ExitState
    
    ReflCheck -- Yes --> GhostCheck{"micro_state ==<br/>STATIC_GHOST?"}
    GhostCheck -- Yes --> GhostDrop["<b>STATE: Ghost Dropped</b><br/>Static reflection with no vital signs.<br/>Clear state, snapshot clutter, abort"]
    
    GhostCheck -- No --> ApneaCount["Increment apnea_frames"]
    ApneaCount --> ApneaLimit{"apnea_frames >=<br/>frame_rate * 5?"}
    ApneaLimit -- Yes --> S2_Apnea["status = Possible Apnea"]
    ApneaLimit -- No --> S2_Still["status = Still / Monitoring..."]
    
    S2_Apnea --> OutputMachine["<b>Output:</b> status,<br/>current_raw_reflection"]
    S2_Still --> OutputMachine
    RawOcc --> OutputMachine