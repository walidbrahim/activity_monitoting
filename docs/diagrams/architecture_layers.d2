direction: right

L1: {
  label: "Layer 1 - Data Acquisition"
  style.fill: "#E0F2FE"
  H: "Profile hardware settings\nIn: YAML profile\nOut: acquisition params"
  P: "RadarController reads radar frames\nIn: hardware params\nOut: raw complex frames"
  Q: "Frame queue (pt_fft_q)\nIn: raw frames\nOut: buffered stream"
  H -> P
  P -> Q
}

L2: {
  label: "Layer 2 - Engine and Translation"
  style.fill: "#ECFDF5"
  F: "Build typed EngineConfig\nIn: AppConfig\nOut: EngineConfig"
  C: "BedMonitorController orchestrates runtime\nIn: queue + config\nOut: app-facing dicts"
  E: "RadarEngine estimates state\nIn: frames + pose + config\nOut: typed estimates"
  O: "EngineOutput\nOut: activity + vitals + respiration models"
  F -> C
  C -> E
  E -> O
}

L3: {
  label: "Layer 3 - App Policy and UI"
  style.fill: "#FFF7ED"
  A1: "Main monitoring app\nIn: app-facing dicts\nOut: workflow"
  A2: "Respiration-focused app\nIn: app-facing dicts\nOut: workflow"
  G: "GUI rendering + display policy\nIn: app state\nOut: plots/badges/labels"
  R: "Robot + alert actions\nIn: policy events\nOut: commands/alerts"
  A1 -> G
  A2 -> G
  A1 -> R
}

CFG: "profiles/base.yaml (+ room overlay)\nIn: user tuning\nOut: merged app profile"

CFG -> L2.F
L1.Q -> L2.C
L2.O -> L3.A1
L2.O -> L3.A2

N1: "Boundary keeps estimation logic independent from GUI code."
N2: "App policy can evolve without changing radar_engine internals."
L2.E -> N1
L3.G -> N2
