flowchart TD
    B["(1) Load base profile<br/>In: profiles/base.yaml<br/>Out: base dict"]
    O["(2) Apply room override (optional)<br/>In: profiles/<room>.yaml<br/>Out: override dict"]
    L["(3) Deep-merge profile sections<br/>In: base + override<br/>Out: merged config dict"]
    AC["(4) Validate layered AppConfig<br/>In: merged dict<br/>Out: typed AppConfig"]
    CF["(5) Map to typed EngineConfig<br/>In: AppConfig<br/>Out: EngineConfig sections"]
    EC["(6) Engine dataclass bundle<br/>In: mapped sections<br/>Out: cohesive EngineConfig"]
    ENG["(7) Construct RadarEngine<br/>In: EngineConfig<br/>Out: initialized engine instance"]

    B --> L
    O --> L
    L --> AC
    AC --> CF
    CF --> EC
    EC --> ENG

    T["High-priority tuning overrides<br/>In: runtime overrides<br/>Out: patch to engine mapping"] --> CF
    N1["Merge rule: merged[key] = override[key] when scalar; recurse when both are objects."]:::note
    N2["Boundary rule: ConfigFactory is the single translation point from YAML/Pydantic to engine dataclasses."]:::note
    L -.-> N1
    CF -.-> N2

    classDef profile fill:#E0F2FE,stroke:#0284C7,color:#0C4A6E;
    classDef typed fill:#ECFDF5,stroke:#10B981,color:#064E3B;
    classDef runtime fill:#FFF7ED,stroke:#F97316,color:#7C2D12;
    classDef note fill:#FFFBEB,stroke:#D97706,color:#7C2D12,stroke-dasharray: 4 3;
    class B,O,L,T profile;
    class AC,CF,EC typed;
    class ENG runtime;
