graph TD
    subgraph "Step 7: Confidence Metrics & Final Output Assembly"
        Input7["<b>Input:</b> posture, Z_b, status, track_confidence,<br/>miss_counter, motion_level, dynamic_mag_profile,<br/>current_raw_reflection"] --> OccConf
        
        OccConf["<b>Occupancy Confidence</b><br/>Temporal: (track_confidence / threshold) * 100"]
        OccConf --> OccSignal{"Status type?"}
        OccSignal -- "Breathing/Moving" --> SigActive["signal_conf from margin above<br/>detection_threshold<br/>(100% if motion > 0.05)"]
        OccSignal -- "Apnea/Still" --> SigApnea["signal_conf from margin above<br/>occupied_reflection * 0.70"]
        OccSignal -- Other --> SigDefault["signal_conf = 100%"]
        
        SigActive --> OccFinal["occ_confidence = 0.6*temporal + 0.4*signal"]
        SigApnea --> OccFinal
        SigDefault --> OccFinal
        OccFinal --> OccPenalty["Subtract penalty for active misses<br/>(miss_counter / miss_allowance) * 100"]
        
        OccPenalty --> PostureConf["<b>Posture Confidence</b><br/>Base = 50 + (dist_to_nearest_threshold / 0.125) * 50<br/>Varies by posture type"]
        PostureConf --> PosturePenalty["Subtract motion_level penalty<br/>(capped at 40, floor at 50%)"]
    end
    
    PosturePenalty --> ZoneTimer
    
    subgraph "Zone Timer & Output Compilation"
        ZoneTimer["<b>Update Zone Timer</b><br/>_update_zone_timer(zone, is_valid, now)"]
        
        subgraph "_update_zone_timer logic"
            ZoneTimer --> New{"Zone changed?"}
            New -- Yes --> StartT["Reset timer start"]
            New -- No --> UpSeen["Update last_seen"]
            
            StartT --> Dropout{"No valid detection?"}
            UpSeen --> Dropout
            
            Dropout -- Yes --> Hold{"Elapsed > hold_sec (3.0s)?"}
            Hold -- Yes --> KillTimer["Reset timer to None"]
            Hold -- No --> TimerOK["Timer still alive"]
            Dropout -- No --> TimerOK
        end
        
        KillTimer --> BuildOutput
        TimerOK --> BuildOutput
        
        BuildOutput["<b>Build Ordered Spectral History</b><br/>_get_ordered_history() from ring buffer<br/>for downstream respiration pipeline"]
        
        BuildOutput --> OutputFinal["<b>Compile output_dict</b><br/>X, Y, Z, final_bin, zone, status,<br/>occ_confidence, posture_confidence,<br/>posture, motion_str, duration_str,<br/>fall_confidence, spectral_history,<br/><b>is_valid = True</b>"]
    end