    subgraph "Per-Frame Processing Loop (process_frame)"
        Step1["<b>1. Hardware Correction & Background</b><br/>Apply Phase Flip, Update Clutter/Baseline, <br/>Subtract Static Environment"] --> Cond1
        
        Cond1{"Is Warmup<br/>Active?"} -- Yes --> OutputCal["Output: Status=Calibrating"]
