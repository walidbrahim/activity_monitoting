graph TD
    Input["<b>Input:</b> raw fft_1d_data <br/>(num_range_bins x 8 antennas, complex)"] --> Step1
    
    subgraph "Per-Frame Processing Loop (process_frame)"
        Step1["<b>1. Hardware Correction & Background</b><br/>Phase Flip, Spatially-Masked Clutter EMA, <br/>Ring-Buffer History Write"] --> Cond1
        
        Cond1{"Warmup<br/>Active?"} -- Yes --> OutputCal["Output: Status=Calibrating<br/>is_valid=False"]
        Cond1 -- No --> Step2
        
        Step2["<b>2. Spatial Candidate Selection</b><br/>Top-N Peaks, AoA via Phase Monopulse,<br/>3D Room Projection, Vital-Sign Gating<br/>(phase_var / SQI classification),<br/>Score & Select Best + Jump Rejection"] --> Step3
        
        Step3["<b>3. State Machine (Occupancy)</b><br/>Zone Name Stripping (base_zone),<br/>Active / Apnea Hold / Ghost Drop / Exit"] --> Cond2
        
        Cond2{"Room Empty /<br/>Target Lost?"} -- Yes --> OutputEmpty["Output: empty_room() dict<br/>is_valid=False"]
        Cond2 -- No --> Step4
        
        Step4["<b>4. Temporal Persistence (Hit/Miss)</b><br/>Confidence Tracking via deque buffer,<br/>Miss Allowance with Dropout Tolerance"] --> Cond3
        
        Cond3{"Miss Allowance<br/>Exceeded?"} -- Yes --> OutputEmpty
        Cond3 -- No --> Step5
        
        Step5["<b>5. Adaptive Smoothing & Velocity</b><br/>Median Filter (deque), Zone-Aware EMA,<br/>Z-History (deque), Vertical Velocity (v_z)"] --> Step6
        
        Step6["<b>6. Posture, Zone & Falls</b><br/>Counter-Based Zone Debounce, Posture by Height,<br/>Motion Tagging, Fall Detection<br/>(Height + Persistence + v_z Velocity Trigger)"] --> Cond4
        
        Cond4{"Ghost / Ignored<br/>Zone?"} -- Yes --> OutputEmpty
        Cond4 -- No --> Step7
        
        Step7["<b>7. Confidence Metrics & Output</b><br/>Occupancy Confidence (temporal + signal),<br/>Posture Confidence (height margin - motion),<br/>Zone Timer, is_valid=True"] --> OutputFinal
        
        OutputFinal["<b>Output:</b> output_dict<br/>(X,Y,Z, Zone, Status, Confidences,<br/>Posture, Duration, spectral_history, is_valid)"]
    end