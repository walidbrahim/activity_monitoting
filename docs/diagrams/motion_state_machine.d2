direction: right

inputs: "INPUTS\nIn: motion_level, micro_state, zone\nOut: branch decision"
walking_check: "WALKING_CHECK"
walking: "WALKING\nOut: label=WALKING, score=0.90, is_walking=true"
normalize: "NORMALIZE\nmotion_score = clamp(motion_level / restless_max, 0, 1)"
resting_check: "RESTING_CHECK\ncutoff = rest_max / restless_max"
resting: "RESTING\nOut: label=RESTING, is_walking=false"
shifting: "SHIFTING\nOut: label=SHIFTING, is_walking=false"
end: "End"

note_formula: "Core Formula\nmotion_score = min(1.0, motion_level / max(restless_max, 1e-9))"
note_walk: "Walking Override\nif micro_state=MACRO_PHASE and motion_level>restless_max\nand zone in {Transit, Floor} -> WALKING"

inputs -> walking_check
walking_check -> walking: "macro phase + high motion + transit/floor"
walking_check -> normalize: "otherwise"

normalize -> resting_check
resting_check -> resting: "motion_score < cutoff"
resting_check -> shifting: "motion_score >= cutoff"

walking -> end
resting -> end
shifting -> end

normalize -> note_formula
walking -> note_walk
