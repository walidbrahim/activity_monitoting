graph TD
    Input["<b>Input:</b> fft_1d_data"] --> Init["Increment frame_count<br/>Copy data"]
    Init --> PhaseFlip["<b>Apply Phase Flip</b><br/>Multiply channels 0,2,4,6 by -1"]
    PhaseFlip --> CalcRawMag["Calculate Raw Magnitude Profile<br/>(Sum abs complex data across 8 channels)"]
    
    subgraph "Baseline Profile Management"
        CalcRawMag --> DecBase{"Baseline exists?"}
        DecBase -- No --> SnapBase["Initialize Baseline = Raw Profile"]
        DecBase -- Yes --> NoOp1["Continue"]
    end
    
    subgraph "Spatially-Masked Clutter Filter"
        SnapBase --> DetAlpha["Determine Clutter Alpha Array"]
        NoOp1 --> DetAlpha
        
        DetAlpha -- Warmup --> A1["alpha[] = 0.3 (all bins)"]
        DetAlpha -- "Empty / No Target" --> A2["alpha[] = config.alpha (all bins)"]
        DetAlpha -- Occupied --> A3["<b>Spatially Masked Alpha</b><br/>Near target: alpha ≈ 0.001 (frozen)<br/>Far bins: alpha = config.alpha (evaporate ghosts)<br/>Blend via distance mask: clip((dist-2)/8, 0, 1)"]
        
        A1 --> UpdateClutter["Update Clutter Map<br/>clutter = alpha * corrected + (1 - alpha) * clutter"]
        A2 --> UpdateClutter
        A3 --> UpdateClutter
        
        UpdateClutter --> Subtract["<b>Subtract Clutter</b><br/>dynamic_data = corrected - clutter_map"]
        Subtract --> DynMag["Calculate Dynamic Magnitude Profile"]
    end
    
    subgraph "Ring-Buffer History & Warmup Exit"
        DynMag --> CheckWarm{"frame_count > warmup_frames?"}
        
        CheckWarm -- Yes --> Hist["<b>Ring-Buffer Write (O(1))</b><br/>complex_history[:, ring_idx % N] = sum(dynamic)<br/>spectral_history[:, ring_idx % N] = sum(dynamic)<br/>Increment ring indices"]
        CheckWarm -- No --> CalStatus["Set Output Status = Calibrating"]
        CalStatus --> CheckEnd{"frame_count == warmup_frames?"}
        CheckEnd -- Yes --> FinalBase["Snapshot Raw Profile to Baseline"]
        CheckEnd -- No --> ExitCal["Return abort=True"]
        FinalBase --> ExitCal
    end
    
    Hist --> FinalWarmExit{"frame == warmup + vital_gate + 1?"}
    FinalWarmExit -- Yes --> ClearTrack["Clear Track Coords / Buffer<br/>(Ready for fresh vital gating)"]
    FinalWarmExit -- No --> Output1["<b>Output:</b> corrected_data,<br/>dynamic_data, dynamic_mag_profile,<br/>raw_mag_profile"]
    ClearTrack --> Output1