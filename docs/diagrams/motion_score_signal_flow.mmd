flowchart LR
    Z["(1) Track and context input<br/>In: tracked target + zone + micro-state<br/>Out: motion-level context"]
    M["(2) Motion estimator<br/>In: motion_level + restless_max<br/>Out: normalized score + coarse label"]
    S["(3) Continuous motion_score<br/>In: estimator output<br/>Out: score in [0,1]"]
    C["(4) App display policy<br/>In: motion_score + label<br/>Out: UI-safe interpretation"]
    L["(5) Coarse motion label<br/>In: estimator label logic<br/>Out: RESTING/SHIFTING/WALKING"]
    U["(6) UI + policy action layer<br/>In: score + label<br/>Out: badges, gating, actions"]

    Z --> M
    M --> S
    S --> C
    C --> L
    S --> U
    L --> U
    N1["Formula: motion_score = clamp(motion_level / restless_max, 0, 1)."]:::note
    N2["Label rule: RESTING if motion_score < rest_max/restless_max, else SHIFTING (unless WALKING gate passes)."]:::note
    N3["Walking override: if MACRO_PHASE and high motion in Transit/Floor zone -> label WALKING."]:::note
    N4["Design rule: use motion_score as primary quantitative signal; use label for human-readable state text."]:::note
    S -.-> N1
    L -.-> N2
    L -.-> N3
    C -.-> N4

    classDef core fill:#F1F5F9,stroke:#334155,color:#0F172A;
    classDef highlight fill:#FEF3C7,stroke:#F59E0B,color:#78350F;
    classDef note fill:#FFFBEB,stroke:#D97706,color:#7C2D12,stroke-dasharray: 4 3;
    class Z,M,C,L,U core;
    class S highlight;
