direction: down

A: "Input stream 1 (activity)\nIn: engine activity dict\nOut: zone/posture/motion_score/motion_str/validity"
R: "Input stream 2 (respiration)\nIn: engine respiration dict\nOut: live signal, RR, apnea, quality"

G1: "(1) On-bed eligibility gate\nIn: is_valid + zone + final_bin + spectral_history\nOut: in_bed bool"
N1: "(1a) Out-of-bed handling\nOut: reset buffers + warning + paused respiration display"
Y1: "(1b) In-bed handling\nOut: continue live update path"

MS: "(2) Motion path (engine-native)\nIn: motion_score + motion_str\nOut: moving/still state"
C1: "(2b) Motion state projection\nOut: UI motion state text"
Q: "(3) Compute signal confidence\nIn: motion_score + posture\nOut: confidence %"

G2: "(4) Marker confidence gate\nIn: confidence %\nOut: show/hide markers"
M1: "Show inhale/exhale markers\nCondition: confidence >= 40%"
M2: "Hide inhale/exhale markers\nCondition: confidence < 40%"
V1: "(5) Quality-driven visuals\nOut: line opacity + quality badge"

G3: "(6) Respiration payload gate\nIn: resp payload present?\nOut: render/clear action"
R0: "Clear apnea overlays and markers"
R1: "Render respiration panels\nOut: signal, RR trend, apnea regions, derivative"

B: "(7) Resp calibration badge gate\nIn: resp.is_calibrating + in_bed\nOut: badge text"
B1: "Status: CALIBRATING"
B2: "Status: LIVE"

A -> G1
G1 -> N1: "No"
G1 -> Y1: "Yes"
Y1 -> MS -> C1 -> Q
Q -> G2
G2 -> M1: "Pass"
G2 -> M2: "Fail"
Q -> V1

R -> G3
G3 -> R0: "No"
G3 -> R1: "Yes"
R -> B
B -> B1: "Calibrating"
B -> B2: "Ready + in-bed"

AN1: "On-bed condition:\nis_valid and zone contains Bed and final_bin exists and spectral_history exists."
AN2: "Motion source:\nmotion_score comes directly from radar_engine (no GUI rescoring)."
AN3: "Moving gate:\nmotion_score >= rest_max/restless_max\n(or moving label: WALKING/SHIFTING)."
AN4: "Confidence formula:\nlower=0.20, upper=0.85\nconfidence = motion_factor(score) x posture_factor x 100."
AN5: "Marker gate:\nshow markers only when confidence >= 40%."
AN6: "Calibration badge:\nCALIBRATING during extractor startup window (~40 s)."

G1 -> AN1
MS -> AN2
MS -> AN3
Q -> AN4
G2 -> AN5
B -> AN6
