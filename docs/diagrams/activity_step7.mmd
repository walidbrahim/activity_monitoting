graph TD
    Input6["<b>Input:</b> X_b, Y_b, Z_b, v_z, motion_level,<br/>is_fallen, persistence_frames, status"] --> ReZone
    
    subgraph "Counter-Based Zone Debouncing"
        ReZone["evaluate_spatial_zone(X_b, Y_b, Z_b)"]
        ReZone --> PushHist["Append zone to zone_history<br/>(deque, maxlen=frames_to_confirm_zone)"]
        PushHist --> FullCheck{"zone_history full?"}
        FullCheck -- Yes --> CountVote["<b>Counter(zone_history).most_common(1)</b><br/>O(n) frequency vote"]
        CountVote --> SetStable["current_stable_zone = winner"]
        FullCheck -- No --> KeepStable["Use current_stable_zone"]
        SetStable --> KeepStable
    end
    
    subgraph "Posture & Motion Tagging"
        KeepStable --> PostureLogic["<b>Posture by Height</b><br/>Z > standing_threshold: Standing<br/>Z > sitting_threshold: Sitting<br/>Else: Lying Down"]
        PostureLogic --> MotionLogic["<b>Motion Tagging</b><br/>Apnea status → Static<br/>motion > restless_max → Major Movement<br/>MACRO_PHASE in Bed/Chair → Postural Shift<br/>motion > rest_max → Restless/Shifting<br/>MICRO_PHASE → Restless/Fidgeting<br/>Else → Resting/Breathing"]
    end
    
    subgraph "Fall Detection (Height + Persistence + Velocity)"
        MotionLogic --> ZoneGate{"Zone is<br/>Ghost/Ignored?"}
        ZoneGate -- Yes --> KillTrack["Kill track, abort"]
        
        ZoneGate -- No --> FloorGate{"Zone is<br/>Floor/Transit?"}
        FloorGate -- No --> BedSafe["Reset fall logic<br/>(is_fallen=False, persistence=0)"]
        BedSafe --> Output6
        
        FloorGate -- Yes --> FloorAdjust["Status → 'In Room'"]
        
        FloorAdjust --> VelocityTrigger{"v_z < fall_velocity_threshold<br/>AND not already fallen?"}
        VelocityTrigger -- Yes --> RapidFall["<b>RAPID DESCENT DETECTED</b><br/>Latch is_fallen=True immediately<br/>(catches fall before hitting floor)"]
        VelocityTrigger -- No --> HeightGate{"Z <= fall_threshold<br/>OR is_fallen latched?"}
        RapidFall --> HeightGate
        
        HeightGate -- Yes --> Fallen["is_fallen=True,<br/>Increment persistence_frames"]
        Fallen --> ScoreFall["<b>Fall Confidence (3-component)</b><br/>h_score (30%): proximity to floor<br/>p_score (40%): duration on floor<br/>v_score (30%): descent velocity magnitude"]
        ScoreFall --> CritGate{"Confidence > 60%?"}
        CritGate -- Yes --> SetCrit["status=CRITICAL Fall Detected<br/>posture=Fallen"]
        CritGate -- No --> Output6
        
        HeightGate -- No --> Recover["Decrement persistence_frames<br/>(slow recovery)"]
        Recover --> Output6
    end
    
    SetCrit --> Output6["<b>Output:</b> final_zone, posture,<br/>motion_str, status, fall_confidence"]