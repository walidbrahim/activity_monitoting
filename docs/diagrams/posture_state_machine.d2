direction: right

input_proxy: "POSTURE_Z_PROXY\nIn: tracked (x,y,z) + valid candidates\nOut: posture_z"
raw_est: "RAW_POSTURE_ESTIMATION"
raw_stand: "RAW_STANDING\nif posture_z >= standing_threshold"
raw_sit: "RAW_SITTING\nif sitting_threshold <= posture_z < standing_threshold"
raw_lie: "RAW_LYING\nif posture_z < sitting_threshold"
buffer_gate: "BUFFER_GATE\nappend raw label to posture_buf"
stable_unknown: "STABLE_UNKNOWN\n(initial)"
stable_stand: "STABLE_STANDING"
stable_sit: "STABLE_SITTING"
stable_lie: "STABLE_LYING"

note_proxy: "Proxy Formula\nposture_z = max(z of nearby candidates) + posture_z_bias\nnearby if distance_xy <= posture_z_neighborhood_m\nfallback: tracked z"
note_conf: "Confidence\nStanding: min(100, 60 + (posture_z - standing_threshold)*80)\nSitting: 70\nLying: min(100, 75 + (sitting_threshold - posture_z)*80)"
note_hys: "Hysteresis Gate\nPOSTURE_CONFIRM = 8 frames\nStable label updates only when all 8 buffered raw labels agree"

input_proxy -> raw_est
raw_est -> raw_stand
raw_est -> raw_sit
raw_est -> raw_lie

raw_stand -> buffer_gate
raw_sit -> buffer_gate
raw_lie -> buffer_gate

buffer_gate -> stable_unknown: "before consensus"
buffer_gate -> stable_stand: "len(buf)==8 AND all==STANDING"
buffer_gate -> stable_sit: "len(buf)==8 AND all==SITTING"
buffer_gate -> stable_lie: "len(buf)==8 AND all==LYING_DOWN"

stable_unknown -> raw_est: "next frame"
stable_stand -> raw_est: "next frame"
stable_sit -> raw_est: "next frame"
stable_lie -> raw_est: "next frame"

input_proxy -> note_proxy
raw_est -> note_conf
buffer_gate -> note_hys
