direction: right

start: "Start"
empty: "EMPTY\nIn: no valid target\nOut: OccupancyState.EMPTY"
entering: "ENTERING\nIn: valid target, entry_frames < FRAMES_TO_OCCUPY\nOut: OccupancyState.ENTERING, conf in [0..50]"
core: "OCCUPANCY_CORE\nIn: is_occupied=true\nOut: MONITORING or OCCUPIED"
monitoring: "MONITORING\nIn: motion in {RESTING, STATIC, FIDGETING}\nOut: OccupancyState.MONITORING"
occupied: "OCCUPIED\nIn: motion active\nOut: OccupancyState.OCCUPIED"
apnea_candidate: "APNEA_CANDIDATE\nIn: apnea_frames >= APNEA_FRAMES\nOut: OccupancyState.APNEA_CANDIDATE"

note_gate: "Gate Parameters\nFRAMES_TO_OCCUPY = int(entry_hold_seconds * 25)\nAPNEA_FRAMES = 150 (default)\nocc_conf = min(100, 60 + target.confidence * 10)"

start -> empty: "init / reset()"

empty -> entering: "target.valid=true\nentry_frames=1"
entering -> entering: "target.valid=true AND entry_frames<FRAMES_TO_OCCUPY\nentry_frames += 1\nconf=(entry_frames/FRAMES_TO_OCCUPY)*50"
entering -> core: "target.valid=true AND entry_frames>=FRAMES_TO_OCCUPY\nis_occupied=true; entry_frames=0"

core -> monitoring: "motion in {RESTING, STATIC, FIDGETING}"
core -> occupied: "otherwise"

monitoring -> monitoring: "target.valid=true AND motion in {RESTING, STATIC, FIDGETING}"
monitoring -> occupied: "target.valid=true AND motion active"

occupied -> occupied: "target.valid=true AND motion active"
occupied -> monitoring: "target.valid=true AND restful AND apnea_frames<APNEA_FRAMES"
occupied -> apnea_candidate: "target.valid=true AND apnea_frames>=APNEA_FRAMES"

apnea_candidate -> monitoring: "target.valid=true AND restful"
apnea_candidate -> occupied: "target.valid=true AND motion active"

entering -> empty: "target.valid=false\n_update_occupancy_empty()"
monitoring -> empty: "target.valid=false\nis_occupied=false; apnea_frames=0"
occupied -> empty: "target.valid=false\nis_occupied=false; apnea_frames=0"
apnea_candidate -> empty: "target.valid=false\nis_occupied=false; apnea_frames=0"

core -> note_gate
