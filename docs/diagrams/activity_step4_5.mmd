graph TD
    subgraph "Step 4: Temporal Persistence (Hit/Miss Tracking)"
        Input4["<b>Input:</b> is_valid_point, raw_x/y/z,<br/>track_confidence, miss_counter"] --> CheckFeat{"temporal_persistence<br/>feature enabled?"}
        
        CheckFeat -- No --> RawValid{"Point Valid?"}
        RawValid -- Yes --> RawSet["Set confidence = threshold,<br/>coord_buffer = deque with point"]
        RawValid -- No --> RawLost["Clear state, empty_room(), abort"]
        RawSet --> Output4["<b>Proceed to Step 5</b>"]
        
        CheckFeat -- Yes --> DecVal{"Point Valid?"}
        
        DecVal -- Yes --> Hit["Increment track_confidence<br/>(capped at threshold)<br/>miss_counter = 0"]
        Hit --> BuffCoord["Append (raw_x,y,z) to<br/>coord_buffer (deque, maxlen=buffer_size)<br/>O(1) append, auto-evicts oldest"]
        
        DecVal -- No --> Miss["Increment miss_counter"]
        Miss --> MissGate{"miss_counter ><br/>miss_allowance?"}
        MissGate -- Yes --> TargetLost["Reset occupation state<br/>Clear tracks, deque buffers"]
        TargetLost --> CallEmpty["empty_room(), abort"]
        
        BuffCoord --> TrackCheck{"track_confidence >=<br/>confidence_threshold?"}
        MissGate -- No --> TrackCheck
        
        TrackCheck -- Yes --> Output4
        TrackCheck -- No --> CallEmpty
    end