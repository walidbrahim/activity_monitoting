direction: right

Z: "Track and context input\nIn: tracked target + zone + micro-state\nOut: motion-level context"
M: "Motion estimator\nIn: motion_level + restless_max\nOut: score + coarse label"
S: "Continuous motion_score\nIn: estimator output\nOut: score in [0,1]"
C: "App display policy\nIn: motion_score + label\nOut: UI-safe interpretation"
L: "Coarse motion label\nOut: RESTING / SHIFTING / WALKING"
U: "UI + policy action layer\nIn: score + label\nOut: badges, gating, actions"

Z -> M
M -> S
S -> C
C -> L
S -> U
L -> U

N1: "Formula:\nmotion_score = clamp(motion_level / restless_max, 0, 1)."
N2: "Label rule:\nRESTING if score < rest_max/restless_max\nelse SHIFTING (unless WALKING override)."
N3: "Walking override:\nif MACRO_PHASE and high motion in Transit/Floor -> WALKING."

S -> N1
L -> N2
L -> N3
